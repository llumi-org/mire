---
import Layout from '../layouts/Layout.astro';

const content = {
    title: "About Mire",
    intro: "Mire is an open platform for sharing scientific and humanistic critiques of real life, along with new research discoveries.",
    mission: "Our Mission",
    missionText: "Mire is a brand under Llumi, known as 'Llumi research'. We aim to provide a seamless, accessible, and professional environment for students and researchers to publish their work, fostering a community of shared knowledge and innovation.",
    features: "Key Features",
    f1: "Markdown-based workflow for easy submission",
    f2: "Automated PDF generation for professional distribution",
    f3: "Multi-language publication support to reach a wider audience",
    join: "Join Us",
    joinText: "We welcome contributions from all disciplines. Start by checking our GitHub repository for submission guidelines."
};
---

<Layout title={`${content.title} - Mire`}>
  <div class="max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h1 class="text-4xl font-extrabold text-gray-900 sm:text-5xl sm:tracking-tight lg:text-6xl">
        {content.title}
      </h1>
      <p class="mt-5 max-w-xl mx-auto text-xl text-gray-500">
        {content.intro}
      </p>
    </div>

    <div class="bg-white overflow-hidden shadow rounded-lg divide-y divide-gray-200">
      <div class="px-4 py-5 sm:p-6">
        <h2 class="text-lg leading-6 font-medium text-gray-900 mb-4">
          {content.mission}
        </h2>
        <p class="text-gray-600 leading-relaxed">
          {content.missionText}
        </p>
      </div>
      <div class="px-4 py-5 sm:p-6">
        <h2 class="text-lg leading-6 font-medium text-gray-900 mb-4">
          {content.features}
        </h2>
        <ul class="list-disc pl-5 space-y-2 text-gray-600">
          <li>{content.f1}</li>
          <li>{content.f2}</li>
          <li>{content.f3}</li>
        </ul>
      </div>
      <div class="px-4 py-5 sm:p-6 bg-indigo-50">
        <h2 class="text-lg leading-6 font-medium text-indigo-900 mb-2">
          {content.join}
        </h2>
        <p class="text-indigo-700 mb-4">
          {content.joinText}
        </p>
        <a href="https://github.com/llumi-org/mire" target="_blank" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700">
          GitHub Repository
        </a>
      </div>
    </div>
  </div>
</Layout>
