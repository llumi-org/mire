---
import Layout from '../layouts/Layout.astro';
import ResearchCard from '../components/ResearchCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('research');
const sortedPosts = posts.sort((a, b) => {
  const dateA = a.data.published || a.data.accepted || a.data.received;
  const dateB = b.data.published || b.data.accepted || b.data.received;
  return dateB.valueOf() - dateA.valueOf();
});
---

<Layout title="Mire - Llumi Research">
  <div class="space-y-12">
    <section class="text-center py-16 bg-gradient-to-b from-indigo-50 to-white rounded-3xl mb-12 border border-indigo-50/50">
      <h1 class="text-5xl font-extrabold text-gray-900 tracking-tight mb-4">
        Discover Student <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-purple-600">Innovation</span>
      </h1>
      <p class="max-w-2xl mx-auto text-xl text-gray-500 leading-relaxed">
        An open platform for sharing scientific and humanistic critiques of real life, along with new research discoveries.
      </p>
      <div class="mt-8 flex justify-center gap-4">
        <a href="#browse" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 transition-all">
          Browse Research
        </a>
        <a href="https://github.com/llumi-org/mire" target="_blank" class="inline-flex items-center px-6 py-3 border border-gray-300 shadow-sm text-base font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 transition-all">
          Submit Paper
        </a>
      </div>
      
      <div class="mt-6 flex justify-center">
        <a href="https://chem-wiki.llumi.org" target="_blank" class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-50 text-emerald-700 rounded-full text-sm font-medium hover:bg-emerald-100 transition-colors border border-emerald-100">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
          </svg>
          Visit our partner: <span class="underline underline-offset-2 font-semibold">Llumi ChemWiki</span>
        </a>
      </div>
    </section>

    <section id="browse">
      <div class="flex items-center justify-between mb-8 flex-wrap gap-4">
        <h2 class="text-3xl font-bold text-gray-900">Latest Research</h2>
        <div class="relative w-full sm:w-64">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
            </svg>
          </div>
          <input type="text" id="search-input" class="focus:ring-indigo-500 focus:border-indigo-500 block w-full pl-10 sm:text-sm border-gray-300 rounded-md py-2 border" placeholder="Search papers...">
        </div>
      </div>
      
      {sortedPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="posts-grid">
          {sortedPosts.map((post) => (
            <div class="research-card-wrapper" data-title={post.data.title.toLowerCase()} data-author={post.data.author.toLowerCase()} data-tags={(post.data.tags || []).join(' ').toLowerCase()}>
              <ResearchCard entry={post} />
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-20 bg-gray-50 rounded-xl border border-dashed border-gray-300">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path vector-effect="non-scaling-stroke" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900">No research papers yet</h3>
          <p class="mt-1 text-sm text-gray-500">Get started by submitting your first research paper.</p>
          <div class="mt-6">
            <a href="https://github.com/llumi-org/mire" target="_blank" class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
              Submit now
            </a>
          </div>
        </div>
      )}
    </section>
  </div>
</Layout>

<script>
  const searchInput = document.getElementById('search-input');
  const grid = document.getElementById('posts-grid');
  const cards = document.querySelectorAll('.research-card-wrapper');

  if (searchInput && grid) {
    searchInput.addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase();
      let hasVisible = false;

      cards.forEach(card => {
        const title = card.getAttribute('data-title');
        const author = card.getAttribute('data-author');
        const tags = card.getAttribute('data-tags');
        
        if (title.includes(term) || author.includes(term) || tags.includes(term)) {
          card.style.display = 'block';
          hasVisible = true;
        } else {
          card.style.display = 'none';
        }
      });
    });
  }
</script>
