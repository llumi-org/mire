---
import { getCollection } from 'astro:content';
import { marked } from 'marked';
import markedKatex from "marked-katex-extension";

marked.use(markedKatex({
  throwOnError: false
}));

import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('research');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const htmlContent = marked.parse(post.body);
const { title, author, received, accepted, published, abstract, language, tags } = post.data;

// Normalize date handling
const primaryDate = published || received;
const dateObj = new Date(primaryDate);
const year = dateObj.getUTCFullYear().toString().slice(-2);
const month = (dateObj.getUTCMonth() + 1).toString().padStart(2, '0');
const authorSlug = author.replace(/\s+/g, '-');

// Calculate PDF filename using the same sorting logic as the PDF generation script
// Posts are sorted by date (ascending) so new posts get higher indices
const allPosts = await getCollection('research');
const sortedPosts = allPosts.sort((a, b) => {
    const dateA = a.data.published || a.data.accepted || a.data.received;
    const dateB = b.data.published || b.data.accepted || b.data.received;
    return dateA.valueOf() - dateB.valueOf() || a.id.localeCompare(b.id);
});
const index = sortedPosts.findIndex(p => p.slug === post.slug) + 1;
const pdfFilename = `mire-${year}${month}-${authorSlug}-${index}.pdf`;

import fs from 'node:fs';
import path from 'node:path';

// Check if PDF exists
const pdfPath = path.join(process.cwd(), 'public', 'pdfs', pdfFilename);
const hasPdf = fs.existsSync(pdfPath);

const formatDate = (date: Date) => date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC'
});

const formattedReceived = received ? formatDate(received) : null;
const formattedAccepted = accepted ? formatDate(accepted) : null;
const formattedPublished = published ? formatDate(published) : null;
---

<Layout title={title} lang={language}>
  <article class="max-w-4xl mx-auto bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <header class="bg-gray-50 border-b border-gray-100 px-8 py-10 text-center">
      <div class="flex items-center justify-center gap-3 mb-6">
        <span class={`px-3 py-1 rounded-full text-xs font-semibold ${language === 'zh' ? 'bg-red-100 text-red-800' : 'bg-blue-100 text-blue-800'}`}>
          {language === 'zh' ? 'Chinese' : 'English'}
        </span>
        <div class="flex flex-col text-sm text-gray-500 font-medium space-y-1">
             {formattedReceived && <time datetime={received.toISOString()}>Received: {formattedReceived}</time>}
             {formattedAccepted && <time datetime={accepted.toISOString()}>Accepted: {formattedAccepted}</time>}
             {formattedPublished && <time datetime={published.toISOString()}>Published: {formattedPublished}</time>}
        </div>
      </div>
      
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-gray-900 mb-6 leading-tight tracking-tight">
        {title}
      </h1>
      
      <div class="flex items-center justify-center gap-2 text-gray-600 font-medium text-lg">
        <span>By {author}</span>
      </div>

       {tags && (
        <div class="flex flex-wrap justify-center gap-2 mt-6">
          {tags.map((tag: string) => (
            <span class="px-2.5 py-0.5 rounded-md text-xs font-medium bg-white border border-gray-200 text-gray-600 shadow-sm">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="px-8 py-10 md:px-12 lg:px-16">
      <div class="bg-indigo-50 border-l-4 border-indigo-500 p-6 rounded-r-lg mb-10">
        <h2 class="text-sm font-bold text-indigo-900 uppercase tracking-wider mb-2">Abstract</h2>
        <p class="text-indigo-800 italic leading-relaxed">
          {abstract}
        </p>
      </div>

      <div class="max-w-none text-gray-700 space-y-4">
        <style is:global>
          @reference "../../styles/global.css";
          .content-wrapper h1 { @apply text-3xl font-bold text-gray-900 mt-8 mb-4; }
          .content-wrapper h2 { @apply text-2xl font-bold text-gray-900 mt-8 mb-4; }
          .content-wrapper h3 { @apply text-xl font-bold text-gray-900 mt-6 mb-3; }
          .content-wrapper p { @apply mb-4 leading-relaxed; }
          .content-wrapper ul { @apply list-disc list-inside mb-4; }
          .content-wrapper ol { @apply list-decimal list-inside mb-4; }
          .content-wrapper blockquote { @apply border-l-4 border-indigo-500 pl-4 py-2 bg-indigo-50 italic my-6; }
          .content-wrapper code { @apply bg-gray-100 px-1 py-0.5 rounded text-sm text-pink-600 font-mono; }
          .content-wrapper pre { @apply bg-gray-900 text-white p-4 rounded-lg overflow-x-auto mb-6; }
          .content-wrapper img { @apply rounded-xl shadow-lg my-6 max-w-full; }
          .content-wrapper a { @apply text-indigo-600 hover:text-indigo-800 underline; }
          .content-wrapper table { @apply w-full border-collapse my-6; }
          .content-wrapper th { @apply border border-gray-300 px-4 py-2 bg-gray-50 font-bold; }
          .content-wrapper td { @apply border border-gray-300 px-4 py-2; }
        </style>
        <div class="content-wrapper" set:html={htmlContent} />
      </div>

      <div class="mt-16 pt-8 border-t border-gray-200 flex flex-col sm:flex-row items-center justify-between gap-4">
        <a href="/" class="text-indigo-600 hover:text-indigo-800 font-medium flex items-center gap-2 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
          </svg>
            Back to research list
        </a>
        
        {hasPdf ? (
        <a href={`/pdfs/${pdfFilename}`} download class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Download PDF Version
        </a>
        ) : (
        <span class="inline-flex items-center px-6 py-3 border border-gray-300 text-base font-medium rounded-md shadow-sm text-gray-400 bg-gray-50 cursor-not-allowed transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          PDF Pending
        </span>
        )}
      </div>
    </div>
  </article>
</Layout>
