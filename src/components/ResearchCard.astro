---
import { getCollection } from 'astro:content';

interface Props {
  entry: any;
}

const { entry } = Astro.props;
const { data, slug } = entry;
const lang = data.language || 'en';

// Normalize date to YYYY-MM-DD to avoid timezone inconsistencies
const primaryDate = data.published || data.accepted || data.received;
const dateObj = new Date(primaryDate);
const formattedDate = dateObj.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC' 
});

// Calculate PDF filename
const allPosts = await getCollection('research');
// Ensure this matches scripts/generate-pdfs.js logic
const sortedPosts = allPosts.sort((a, b) => {
    const dateA = a.data.published || a.data.accepted || a.data.received;
    const dateB = b.data.published || b.data.accepted || b.data.received;
    return dateA.valueOf() - dateB.valueOf() || a.id.localeCompare(b.id);
});
const index = sortedPosts.findIndex(p => p.slug === slug) + 1;

const year = dateObj.getUTCFullYear().toString().slice(-2);
const month = (dateObj.getUTCMonth() + 1).toString().padStart(2, '0');
const authorSlug = data.author.replace(/\s+/g, '-');
const pdfFilename = `mire-${year}${month}-${authorSlug}-${index}.pdf`;

import fs from 'node:fs';
import path from 'node:path';

// Check if PDF exists in public folder
// In development/build, public files are in 'public'
const pdfPath = path.join(process.cwd(), 'public', 'pdfs', pdfFilename);
const hasPdf = fs.existsSync(pdfPath);
---

<article class="bg-white rounded-xl shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 border border-gray-100 flex flex-col h-full overflow-hidden group">
  <div class="p-6 flex-grow flex flex-col">
    <div class="flex items-center justify-between mb-4">
      <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${data.language === 'zh' ? 'bg-red-50 text-red-700 border border-red-100' : 'bg-blue-50 text-blue-700 border border-blue-100'}`}>
        {data.language === 'zh' ? 'Chinese' : 'English'}
      </span>
      <time datetime={dateObj.toISOString()} class="text-xs text-gray-400 font-medium uppercase tracking-wide">
         {data.published ? 'Pub: ' : data.accepted ? 'Acc: ' : 'Rec: '}
         {formattedDate}
      </time>
    </div>
    
    <a href={`/research/${slug}`} class="block mb-3">
      <h3 class="text-xl font-bold text-gray-900 group-hover:text-indigo-600 transition-colors leading-tight">
        {data.title}
      </h3>
    </a>
    
    <p class="text-sm text-gray-600 mb-4 font-medium flex items-center gap-2">
      <span class="w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-xs text-gray-500">
        {data.author.charAt(0)}
      </span>
      {data.author}
    </p>
    
    <p class="text-gray-500 text-sm line-clamp-3 mb-6 leading-relaxed flex-grow">
      {data.abstract}
    </p>

    <div class="flex flex-wrap gap-2 mt-auto">
       {data.tags && data.tags.map((tag: string) => (
         <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">
           #{tag}
         </span>
       ))}
    </div>
  </div>
  
  <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-between items-center">
    <a href={`/research/${slug}`} class="text-indigo-600 hover:text-indigo-800 text-sm font-semibold flex items-center gap-1 transition-colors group/link">
      Read Article
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover/link:translate-x-0.5 transition-transform" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
      </svg>
    </a>
    
    {hasPdf ? (
      <a href={`/pdfs/${pdfFilename}`} download class="text-gray-500 hover:text-gray-900 text-sm font-medium flex items-center gap-1.5 transition-colors px-3 py-1.5 rounded-md hover:bg-gray-200" title="Download PDF">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        PDF
      </a>
    ) : (
      <span class="text-gray-300 text-sm font-medium flex items-center gap-1.5 px-3 py-1.5 cursor-not-allowed" title="PDF Pending">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Pending
      </span>
    )}
  </div>
</article>
